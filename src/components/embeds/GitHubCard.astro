---
interface Props {
  url: string;
  label?: string;
}

const { url, label } = Astro.props;

const match = url.match(/github\.com\/([^/]+)\/([^/#?]+)/);
const owner = match?.[1];
const repo = match?.[2]?.replace(/\.git$/, '');

type RepoData = {
  description: string | null;
  stargazers_count: number;
  language: string | null;
  full_name: string;
  html_url: string;
};

let data: RepoData | null = null;
if (owner && repo) {
  try {
    const res = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {
      headers: {
        Accept: 'application/vnd.github+json',
        'User-Agent': 'sound-blog',
      },
    });
    if (res.ok) data = (await res.json()) as RepoData;
  } catch {}
}
---

<a class="gh-card" href={url} target="_blank" rel="noopener noreferrer">
  <span class="gh-card__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
      <path d="M12 .5C5.73.5.77 5.46.77 11.73c0 4.97 3.22 9.18 7.7 10.67.56.1.77-.24.77-.54 0-.27-.01-1.15-.02-2.08-3.13.68-3.79-1.34-3.79-1.34-.51-1.3-1.25-1.65-1.25-1.65-1.02-.7.08-.68.08-.68 1.13.08 1.72 1.16 1.72 1.16 1 1.72 2.63 1.22 3.27.93.1-.73.39-1.22.71-1.5-2.5-.28-5.12-1.25-5.12-5.58 0-1.23.44-2.24 1.16-3.03-.12-.28-.5-1.44.11-3 0 0 .95-.3 3.11 1.16.9-.25 1.87-.38 2.83-.39.96.01 1.93.14 2.83.39 2.16-1.46 3.11-1.16 3.11-1.16.61 1.56.23 2.72.11 3 .72.79 1.16 1.8 1.16 3.03 0 4.34-2.63 5.3-5.14 5.57.4.35.76 1.03.76 2.09 0 1.51-.01 2.72-.01 3.09 0 .3.2.65.78.54 4.47-1.49 7.69-5.7 7.69-10.67C23.23 5.46 18.27.5 12 .5Z"/>
    </svg>
  </span>
  <span class="gh-card__body">
    <span class="gh-card__title">{label ?? (owner && repo ? `${owner}/${repo}` : url)}</span>
    {data?.description && <span class="gh-card__desc">{data.description}</span>}
    {data && (
      <span class="gh-card__meta">
        {data.language && <span>{data.language}</span>}
        <span>★ {data.stargazers_count.toLocaleString()}</span>
      </span>
    )}
  </span>
  <span class="gh-card__arrow" aria-hidden="true">↗</span>
</a>
