---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const builds = (await getCollection('builds')).sort(
  (a, b) => +b.data.started - +a.data.started,
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' }).toUpperCase();
---

<Base title="Builds · sound/blog" description="Things I'm making as I learn.">
  <section class="hero wrap reveal">
    <p class="eyebrow hero__eyebrow">Workshop · {String(builds.length).padStart(2, '0')} entries</p>
    <h1 class="hero__title">Builds &amp; <em>experiments</em>.</h1>
    <p class="hero__lede">
      Small audio projects &mdash; plugins, tools, demos &mdash; in various states of repair. The
      half-finished ones count too.
    </p>
  </section>

  <div class="wrap">
    <div class="section-rule">
      <span class="section-rule__label">Workshop</span>
      <span class="section-rule__line"></span>
      <svg class="section-rule__glyph" viewBox="0 0 24 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M 0 6 Q 3 0 6 6 T 12 6 T 18 6 T 24 6" />
      </svg>
    </div>

    <div class="builds-grid reveal">
      {builds.map((b) => (
        <a class="build-card" href={`/builds/${b.id}/`}>
          <span class="build-card__status" data-status={b.data.status}>
            {b.data.status === 'wip' ? 'In progress' : b.data.status === 'shipped' ? 'Shipped' : 'Paused'}
            &nbsp;·&nbsp;{fmtDate(b.data.started)}
          </span>
          <h2 class="build-card__title">{b.data.title}</h2>
          {b.data.summary && <p class="build-card__summary">{b.data.summary}</p>}
          {b.data.tags.length > 0 && (
            <p class="entry__tags">
              {b.data.tags.map((t) => <span>{t}</span>)}
            </p>
          )}
        </a>
      ))}
    </div>

    {builds.length === 0 && (
      <p class="entry__summary" style="padding-block: 2rem">
        Nothing in the workshop yet. Drop a <code>.md</code> file in <code>src/content/builds/</code>.
      </p>
    )}
  </div>
</Base>
