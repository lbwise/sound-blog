---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('posts', (p) => !p.data.draft);
const posts = all.sort((a, b) => +b.data.date - +a.data.date);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
    .replace(/ /g, ' ')
    .toUpperCase();

const total = posts.length;
---

<Base>
  <section class="hero wrap reveal">
    <p class="eyebrow hero__eyebrow">Since 17 APR 2026 · Log № {String(total).padStart(3, '0')}</p>
    <h1 class="hero__title">Learning <em>audio</em> out loud.</h1>
    <p class="hero__lede">
      A public notebook for figuring out DSP, audio engineering, and the machinery of the
      music industry. Posted raw, from the first sine wave onward &mdash; because documentation
      is part of the work, not something you do after.
    </p>
  </section>

  <div class="wrap">
    <div class="section-rule">
      <span class="section-rule__label">The Journal</span>
      <span class="section-rule__line"></span>
      <svg class="section-rule__glyph" viewBox="0 0 24 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M 0 6 Q 3 0 6 6 T 12 6 T 18 6 T 24 6" />
      </svg>
    </div>

    <ol class="entries reveal" role="list">
      {posts.map((post, i) => {
        const n = post.data.number ?? (posts.length - i);
        const num = String(n).padStart(3, '0');
        return (
          <li class="entry">
            <p class="entry__num">№ {num}</p>
            <div class="entry__head">
              <h2 class="entry__title">
                <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              </h2>
              <time class="entry__date" datetime={post.data.date.toISOString()}>
                {fmtDate(post.data.date)}
              </time>
            </div>
            {post.data.summary && <p class="entry__summary">{post.data.summary}</p>}
            {post.data.tags.length > 0 && (
              <p class="entry__tags">
                {post.data.tags.map((t) => <span>{t}</span>)}
              </p>
            )}
          </li>
        );
      })}
    </ol>

    {posts.length === 0 && (
      <p class="entry__summary" style="padding-block: 2rem">
        Nothing posted yet. Drop a <code>.md</code> file in <code>src/content/posts/</code> and it'll appear here.
      </p>
    )}
  </div>
</Base>
